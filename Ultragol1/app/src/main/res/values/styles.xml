<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Ultragol" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <style name="Theme.Ultragol.Splash" parent="Theme.Ultragol">
        <item name="android:windowFullscreen">true</item>
    </style>
    <style name="GlassBottomSheetTheme" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/GlassBottomSheet</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>
    <style name="GlassBottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
    <style name="FullScreenServerDialog" parent="@android:style/Theme.Translucent.NoTitleBar.Fullscreen">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
    <style name="UpdateDialogTheme" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.75</item>
        <item name="buttonBarPositiveButtonStyle">@style/UpdatePositiveBtn</item>
        <item name="buttonBarNegativeButtonStyle">@style/UpdateNegativeBtn</item>
    </style>
    <style name="UpdatePositiveBtn" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="backgroundTint">#FF6B00</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>
    <style name="UpdateNegativeBtn" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#66FFFFFF</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
