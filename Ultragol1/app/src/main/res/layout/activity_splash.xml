<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_primary">
    <View android:layout_width="match_parent" android:layout_height="match_parent"
        android:background="@drawable/gradient_radial_splash"/>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:orientation="vertical" android:gravity="center">
        <LinearLayout android:id="@+id/splashLogo"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ULTRA" android:textColor="#FFFFFF" android:textSize="42sp"
                android:fontFamily="sans-serif-black" android:letterSpacing="0.05"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GOL" android:textColor="@color/orange_primary" android:textSize="42sp"
                android:fontFamily="sans-serif-black" android:letterSpacing="0.05"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="1" android:textColor="#FFFFFF" android:textSize="32sp"
                android:fontFamily="sans-serif-black"/>
        </LinearLayout>
        <TextView android:id="@+id/splashTagline"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="12dp" android:text="Streaming sin límites"
            android:textColor="#99FFFFFF" android:textSize="15sp"
            android:visibility="invisible" android:letterSpacing="0.08"/>
        <ProgressBar android:id="@+id/splashProgress"
            android:layout_width="120dp" android:layout_height="3dp"
            android:layout_marginTop="40dp" android:progressDrawable="@drawable/progress_orange"
            android:indeterminate="true" android:visibility="invisible"
            style="@android:style/Widget.ProgressBar.Horizontal"/>
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal" android:layout_marginBottom="32dp"
        android:text="v1.0" android:textColor="#33FFFFFF" android:textSize="12sp"/>
</FrameLayout>
