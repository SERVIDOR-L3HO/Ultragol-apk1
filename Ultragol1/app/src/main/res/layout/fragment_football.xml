<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A14">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:background="@drawable/sport_header_bg">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚽  DEPORTES"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.06"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/sport_match_live_card"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="#E53935"
                android:layout_marginEnd="6dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EN VIVO"
                android:textColor="#FF6565"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Gold divider -->
    <View android:layout_width="match_parent" android:layout_height="2dp"
        android:background="#30FFB800"/>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/footballLoading"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:indeterminateTint="#FF6B00"
        android:visibility="gone"/>

    <!-- Error -->
    <TextView
        android:id="@+id/footballError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#55FFFFFF"
        android:textSize="14sp"
        android:padding="24dp"
        android:visibility="gone"/>

    <!-- Agenda content -->
    <ScrollView
        android:id="@+id/footballScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/footballContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="40dp"/>
    </ScrollView>

</LinearLayout>
