<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/bg_surface">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚽ Deportes"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-bold"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● EN VIVO"
            android:textColor="#4CAF50"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            android:letterSpacing="0.08"/>
    </LinearLayout>

    <!-- League tab bar -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:scrollbars="none"
        android:background="@color/bg_surface"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <LinearLayout
            android:id="@+id/leagueTabBar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- Section (sub) tab bar -->
    <HorizontalScrollView
        android:id="@+id/sectionTabScroll"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:scrollbars="none"
        android:background="#0DFFFFFF"
        android:paddingStart="10dp"
        android:paddingTop="6dp"
        android:paddingEnd="10dp"
        android:paddingBottom="6dp"
        android:visibility="gone">
        <LinearLayout
            android:id="@+id/sectionTabBar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"/>
    </HorizontalScrollView>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/footballLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:indeterminateTint="@color/orange_primary"
        android:visibility="gone"/>

    <!-- Error -->
    <TextView
        android:id="@+id/footballError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="#55FFFFFF"
        android:textSize="14sp"
        android:padding="24dp"
        android:visibility="gone"/>

    <!-- Content scroll -->
    <ScrollView
        android:id="@+id/footballScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/footballContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp"/>
    </ScrollView>

</LinearLayout>
