<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/glassCard"
    android:layout_width="320dp"
    android:layout_height="172dp"
    android:layout_marginEnd="14dp"
    android:background="@drawable/live_card_main_bg"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Orange glow spot on left logo zone -->
    <View
        android:layout_width="170dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/live_card_left_glow"/>

    <!-- Left logo zone -->
    <LinearLayout
        android:layout_width="148dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/cardLogo"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:background="@drawable/live_logo_ring"
            android:padding="11dp"
            android:scaleType="centerInside"
            android:contentDescription="logo"/>
    </LinearLayout>

    <!-- Vertical separator -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:layout_marginStart="148dp"
        android:background="#20FFFFFF"/>

    <!-- Right glass info panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="162dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- League pill -->
        <TextView
            android:id="@+id/cardLeague"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFF6B00"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:maxLines="1"
            android:ellipsize="end"
            android:background="@drawable/league_pill_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginBottom="7dp"/>

        <!-- Match title -->
        <TextView
            android:id="@+id/cardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="6dp"/>

        <!-- Time row -->
        <TextView
            android:id="@+id/cardTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#66FFFFFF"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="11dp"/>

        <!-- CTA button -->
        <TextView
            android:id="@+id/cardCta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶  Ver ahora"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/live_cta_glass_btn"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"/>

    </LinearLayout>

    <!-- ● EN VIVO badge — top left -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="10dp"
        android:text="● EN VIVO"
        android:textColor="#FF00E676"
        android:textSize="8sp"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:background="@drawable/badge_live_green"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"/>

    <!-- Server count badge — top right -->
    <TextView
        android:id="@+id/cardServerCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="10dp"
        android:textColor="#FFFF6B00"
        android:textSize="8sp"
        android:textStyle="bold"
        android:background="@drawable/live_server_number_bg"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"/>

</FrameLayout>
