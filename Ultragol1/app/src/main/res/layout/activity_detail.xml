<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero backdrop -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">
            <ImageView
                android:id="@+id/detailBackdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_detail_bottom"/>
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/gradient_top_black"/>

            <!-- Back button glass -->
            <FrameLayout
                android:id="@+id/btnDetailBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:background="@drawable/back_btn_glass"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"/>
            </FrameLayout>

            <!-- HD Badge -->
            <TextView
                android:id="@+id/detailBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:background="@drawable/badge_new"
                android:text="HD"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"/>
        </FrameLayout>

        <!-- Glass info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:layout_marginTop="-30dp">

            <!-- Poster -->
            <ImageView
                android:id="@+id/detailPoster"
                android:layout_width="100dp"
                android:layout_height="148dp"
                android:scaleType="centerCrop"
                android:background="@drawable/poster_glass_bg"/>

            <!-- Title & meta -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical"
                android:paddingTop="36dp">

                <TextView
                    android:id="@+id/detailTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:maxLines="3"
                    android:lineSpacingMultiplier="1.1"/>

                <TextView
                    android:id="@+id/detailMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ "
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/detailRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>

                <!-- Genre chips -->
                <LinearLayout
                    android:id="@+id/genreChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:gravity="center_vertical">

            <!-- Play button -->
            <LinearLayout
                android:id="@+id/btnPlay"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_play_white_bg"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶  "
                    android:textColor="#0A0A0F"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ver ahora"
                    android:textColor="#0A0A0F"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"/>
            </LinearLayout>

            <!-- Add button -->
            <LinearLayout
                android:id="@+id/btnAdd"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:background="@drawable/btn_action_glass"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-light"/>
            </LinearLayout>

            <!-- Share button -->
            <LinearLayout
                android:id="@+id/btnShare"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:background="@drawable/btn_action_glass"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↑"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Synopsis glass card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:marginStart="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            android:padding="16dp"
            android:background="@drawable/synopsis_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sinopsis"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:textAllCaps="true"/>

            <TextView
                android:id="@+id/detailOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.6"
                android:maxLines="4"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/btnReadMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Leer más"
                android:textColor="@color/orange_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-bold"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="14dp"
            android:padding="16dp"
            android:background="@drawable/glass_card_bg"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Año"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"/>
                <TextView
                    android:id="@+id/statYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@drawable/divider_vertical_glass"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Rating"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"/>
                <TextView
                    android:id="@+id/statRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="@drawable/divider_vertical_glass"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎬"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Género"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"/>
                <TextView
                    android:id="@+id/statGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Tabs bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:padding="4dp"
            android:background="@drawable/tab_bar_bg"
            android:gravity="center">

            <TextView
                android:id="@+id/tabInfo"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Info"
                android:textColor="#0A0A0F"
                android:textSize="13sp"
                android:fontFamily="sans-serif-bold"
                android:background="@drawable/tab_selected_bg"/>

            <TextView
                android:id="@+id/tabSimilar"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Similares"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tabVideos"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Videos"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tabReparto"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Reparto"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="40dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
