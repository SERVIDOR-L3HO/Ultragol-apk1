<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/episode_card_bg"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Thumbnail -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="190dp">

        <ImageView
            android:id="@+id/ivEpStill"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="#1A1A2E"/>

        <!-- Dark gradient overlay on bottom of thumbnail -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/ep_thumb_gradient"/>

        <!-- EP badge top-left -->
        <TextView
            android:id="@+id/tvEpBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="10dp"
            android:background="@drawable/ep_badge_bg"
            android:text="EP 1"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <!-- Duration badge top-right -->
        <LinearLayout
            android:id="@+id/tvEpDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="10dp"
            android:background="@drawable/ep_duration_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">
            <TextView
                android:id="@+id/tvEpDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45 min"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>
    </FrameLayout>

    <!-- Info section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <!-- Episode title -->
        <TextView
            android:id="@+id/tvEpTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título del episodio"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="5dp"/>

        <!-- Synopsis -->
        <TextView
            android:id="@+id/tvEpOverview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#99FFFFFF"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="8dp"/>

        <!-- Series · S01E01 -->
        <TextView
            android:id="@+id/tvEpCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Serie · S01E01"
            android:textColor="#55FFFFFF"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.04"/>
    </LinearLayout>
</LinearLayout>
