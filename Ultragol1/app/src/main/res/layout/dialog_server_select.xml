<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:background="@drawable/bottom_sheet_bg"
    android:paddingTop="12dp" android:paddingBottom="24dp">
    <!-- Handle -->
    <View android:layout_width="36dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginBottom="12dp"
        android:background="@drawable/sheet_handle"/>
    <!-- Title -->
    <TextView android:id="@+id/serverDialogTitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingBottom="14dp"
        android:textColor="#FFFFFF" android:textSize="16sp" android:fontFamily="sans-serif-bold"
        android:maxLines="2" android:ellipsize="end"/>
    <!-- Episode section (for series) -->
    <LinearLayout android:id="@+id/episodeSection"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingBottom="12dp"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="T:" android:textColor="#99FFFFFF" android:textSize="13sp" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/btnSeasonMinus"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_round_dark" android:text="−"
            android:textColor="#FFFFFF" android:textSize="16sp" android:gravity="center"
            android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/tvSeason"
            android:layout_width="36dp" android:layout_height="wrap_content"
            android:text="1" android:textColor="#FFFFFF" android:textSize="15sp"
            android:gravity="center" android:fontFamily="sans-serif-bold"/>
        <TextView android:id="@+id/btnSeasonPlus"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_round_dark" android:text="+"
            android:textColor="#FFFFFF" android:textSize="16sp" android:gravity="center"
            android:clickable="true" android:focusable="true"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="  E:" android:textColor="#99FFFFFF" android:textSize="13sp" android:layout_marginEnd="6dp"/>
        <TextView android:id="@+id/btnEpMinus"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_round_dark" android:text="−"
            android:textColor="#FFFFFF" android:textSize="16sp" android:gravity="center"
            android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/tvEpisode"
            android:layout_width="36dp" android:layout_height="wrap_content"
            android:text="1" android:textColor="#FFFFFF" android:textSize="15sp"
            android:gravity="center" android:fontFamily="sans-serif-bold"/>
        <TextView android:id="@+id/btnEpPlus"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_round_dark" android:text="+"
            android:textColor="#FFFFFF" android:textSize="16sp" android:gravity="center"
            android:clickable="true" android:focusable="true"/>
        <LinearLayout android:id="@+id/btnLoadEpisode"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:layout_marginStart="10dp" android:background="@drawable/tab_active"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Cargar" android:textColor="#FFFFFF" android:textSize="12sp"
                android:fontFamily="sans-serif-bold"/>
        </LinearLayout>
    </LinearLayout>
    <!-- Lang tabs -->
    <LinearLayout android:id="@+id/langTabs"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
        android:paddingBottom="10dp" android:visibility="gone">
        <TextView android:id="@+id/tabLatino"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:layout_marginEnd="6dp" android:gravity="center"
            android:background="@drawable/tab_active" android:text="Latino"
            android:textColor="#FFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-bold"/>
        <TextView android:id="@+id/tabEspanol"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:layout_marginEnd="6dp" android:gravity="center"
            android:background="@drawable/tab_inactive" android:text="Español"
            android:textColor="#99FFFFFF" android:textSize="12sp"/>
        <TextView android:id="@+id/tabSubtitulado"
            android:layout_width="0dp" android:layout_height="34dp" android:layout_weight="1"
            android:gravity="center" android:background="@drawable/tab_inactive"
            android:text="Sub" android:textColor="#99FFFFFF" android:textSize="12sp"/>
    </LinearLayout>
    <!-- Servers -->
    <ProgressBar android:id="@+id/loadingServers"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"/>
    <TextView android:id="@+id/errorServers"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="center" android:layout_marginTop="10dp"
        android:text="No se encontraron servidores" android:textColor="#99FFFFFF"
        android:textSize="13sp" android:visibility="gone"/>
    <LinearLayout android:id="@+id/serverContainer"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical"/>
</LinearLayout>
