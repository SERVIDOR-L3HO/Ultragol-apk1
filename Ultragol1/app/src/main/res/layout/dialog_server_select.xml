<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BF000000">

    <!-- Tap outside to dismiss -->
    <View
        android:id="@+id/dialogDismiss"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Content info: bottom-left -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="56dp"
        android:orientation="horizontal"
        android:gravity="bottom">

        <ImageView
            android:id="@+id/dialogPoster"
            android:layout_width="64dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:background="@drawable/poster_glass_bg"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:gravity="bottom">

            <TextView
                android:id="@+id/dialogBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/detail_type_badge_bg"
                android:text="FILM"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"/>

            <TextView
                android:id="@+id/serverDialogTitle"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:fontFamily="sans-serif-black"
                android:maxLines="3"
                android:lineSpacingMultiplier="1.1"/>
        </LinearLayout>
    </LinearLayout>

    <!-- SOURCE FOUND -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/server_radio_dot"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOURCE FOUND"
            android:textColor="#66FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif-bold"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <!-- Episode controls (series only) -->
    <LinearLayout
        android:id="@+id/episodeSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T "
            android:textColor="#88FFFFFF"
            android:textSize="12sp"/>
        <TextView android:id="@+id/btnSeasonMinus"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_round_dark" android:text="−"
            android:textColor="#FFFFFF" android:textSize="16sp" android:gravity="center"
            android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/tvSeason"
            android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="1" android:textColor="#FFFFFF" android:textSize="14sp"
            android:gravity="center" android:fontFamily="sans-serif-bold"/>
        <TextView android:id="@+id/btnSeasonPlus"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_round_dark" android:text="+"
            android:textColor="#FFFFFF" android:textSize="16sp" android:gravity="center"
            android:clickable="true" android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  E "
            android:textColor="#88FFFFFF"
            android:textSize="12sp"/>
        <TextView android:id="@+id/btnEpMinus"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_round_dark" android:text="−"
            android:textColor="#FFFFFF" android:textSize="16sp" android:gravity="center"
            android:clickable="true" android:focusable="true"/>
        <TextView android:id="@+id/tvEpisode"
            android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="1" android:textColor="#FFFFFF" android:textSize="14sp"
            android:gravity="center" android:fontFamily="sans-serif-bold"/>
        <TextView android:id="@+id/btnEpPlus"
            android:layout_width="28dp" android:layout_height="28dp"
            android:background="@drawable/btn_round_dark" android:text="+"
            android:textColor="#FFFFFF" android:textSize="16sp" android:gravity="center"
            android:clickable="true" android:focusable="true"/>

        <LinearLayout android:id="@+id/btnLoadEpisode"
            android:layout_width="60dp" android:layout_height="30dp"
            android:layout_marginStart="8dp" android:background="@drawable/btn_ver_ahora_bg"
            android:gravity="center" android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="OK" android:textColor="#FFFFFF" android:textSize="12sp"
                android:fontFamily="sans-serif-bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Server list: right side, centered vertically -->
    <LinearLayout
        android:layout_width="230dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/loadingServers"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:indeterminateTint="#FFFFFF"
            android:visibility="visible"/>

        <!-- Error -->
        <TextView
            android:id="@+id/errorServers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="Sin servidores"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:visibility="gone"/>

        <!-- Lang tabs (right-aligned) -->
        <LinearLayout
            android:id="@+id/langTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end"
            android:layout_marginBottom="12dp"
            android:gravity="end"
            android:visibility="gone">
            <TextView android:id="@+id/tabLatino"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/tab_active" android:text="Latino"
                android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="sans-serif-bold"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:gravity="center"/>
            <TextView android:id="@+id/tabEspanol"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/tab_inactive" android:text="Español"
                android:textColor="#99FFFFFF" android:textSize="11sp"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:gravity="center"/>
            <TextView android:id="@+id/tabSubtitulado"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/tab_inactive" android:text="Sub"
                android:textColor="#99FFFFFF" android:textSize="11sp"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:gravity="center"/>
        </LinearLayout>

        <!-- Server rows container -->
        <LinearLayout
            android:id="@+id/serverContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </LinearLayout>

</FrameLayout>
