<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <!-- Tap outside to dismiss -->
    <View
        android:id="@+id/dialogDismiss"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"/>

    <!-- BOTTOM GLASS SHEET -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/glass_dialog_panel_bg"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="14dp"
            android:paddingBottom="36dp">

            <!-- Sheet drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="@drawable/sheet_handle"/>

            <!-- Content info: poster + title + badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/dialogPoster"
                    android:layout_width="52dp"
                    android:layout_height="74dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/poster_glass_bg"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:id="@+id/dialogBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/detail_type_badge_bg"
                        android:text="FILM"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.08"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"/>

                    <TextView
                        android:id="@+id/serverDialogTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:maxLines="2"
                        android:lineSpacingMultiplier="1.1"/>

                    <!-- SOURCE FOUND indicator -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="7dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/server_radio_dot"
                            android:layout_marginEnd="5dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOURCE FOUND"
                            android:textColor="#55FFFFFF"
                            android:textSize="9sp"
                            android:fontFamily="sans-serif-bold"
                            android:letterSpacing="0.12"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════
                 EPISODE SECTION — glass card, series only
                 ═══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/episodeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:background="@drawable/glass_card_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶  SELECCIONAR EPISODIO"
                    android:textColor="#66FFFFFF"
                    android:textSize="9sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.14"
                    android:layout_marginBottom="14dp"/>

                <!-- Temporada + Episodio steppers side by side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <!-- Temporada glass stepper -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/glass_stepper_bg"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TEMPORADA"
                            android:textColor="#66FFFFFF"
                            android:textSize="8sp"
                            android:fontFamily="sans-serif-bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="10dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView android:id="@+id/btnSeasonMinus"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/btn_round_dark"
                                android:text="−"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"/>

                            <TextView android:id="@+id/tvSeason"
                                android:layout_width="42dp"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:gravity="center"
                                android:fontFamily="sans-serif-black"/>

                            <TextView android:id="@+id/btnSeasonPlus"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/btn_round_dark"
                                android:text="+"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Episodio glass stepper -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/glass_stepper_bg"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EPISODIO"
                            android:textColor="#66FFFFFF"
                            android:textSize="8sp"
                            android:fontFamily="sans-serif-bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="10dp"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView android:id="@+id/btnEpMinus"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/btn_round_dark"
                                android:text="−"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"/>

                            <TextView android:id="@+id/tvEpisode"
                                android:layout_width="42dp"
                                android:layout_height="wrap_content"
                                android:text="1"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:gravity="center"
                                android:fontFamily="sans-serif-black"/>

                            <TextView android:id="@+id/btnEpPlus"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/btn_round_dark"
                                android:text="+"
                                android:textColor="#FFFFFF"
                                android:textSize="20sp"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Cargar episodio button -->
                <LinearLayout android:id="@+id/btnLoadEpisode"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:background="@drawable/btn_ver_ahora_bg"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶  Cargar episodio"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Thin glass divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF"
                android:layout_marginBottom="16dp"/>

            <!-- Loading spinner -->
            <ProgressBar
                android:id="@+id/loadingServers"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center_horizontal"
                android:indeterminateTint="#FFFFFF"
                android:visibility="visible"/>

            <!-- Error state -->
            <TextView
                android:id="@+id/errorServers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Sin servidores disponibles"
                android:textColor="#55FFFFFF"
                android:textSize="12sp"
                android:visibility="gone"/>

            <!-- Language tabs -->
            <LinearLayout
                android:id="@+id/langTabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:gravity="start"
                android:visibility="gone">
                <TextView android:id="@+id/tabLatino"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/tab_active"
                    android:text="Latino"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-bold"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:gravity="center"/>
                <TextView android:id="@+id/tabEspanol"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/tab_inactive"
                    android:text="Español"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:gravity="center"/>
                <TextView android:id="@+id/tabSubtitulado"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:background="@drawable/tab_inactive"
                    android:text="Sub"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Server rows -->
            <LinearLayout
                android:id="@+id/serverContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
