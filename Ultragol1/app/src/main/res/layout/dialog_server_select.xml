<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <!-- Tap outside to dismiss -->
    <View
        android:id="@+id/dialogDismiss"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Bottom sheet panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_bg"
        android:paddingBottom="24dp">

        <!-- Sheet handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/sheet_handle"/>

        <!-- Header: poster + info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="14dp">

            <ImageView
                android:id="@+id/dialogPoster"
                android:layout_width="52dp"
                android:layout_height="76dp"
                android:scaleType="centerCrop"
                android:background="@drawable/poster_glass_bg"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/dialogBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/detail_type_badge_bg"
                    android:text="FILM"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.08"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"/>

                <TextView
                    android:id="@+id/serverDialogTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:maxLines="2"
                    android:lineSpacingMultiplier="1.1"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:background="@drawable/server_radio_dot"
                        android:layout_marginEnd="5dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SOURCE FOUND"
                        android:textColor="#55FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.1"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="#1AFFFFFF"/>

        <!-- Episode controls (series only) -->
        <LinearLayout
            android:id="@+id/episodeSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/episode_card_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Temporada"
                    android:textColor="#AAFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold"/>

                <TextView android:id="@+id/btnSeasonMinus"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:background="@drawable/btn_round_dark" android:text="−"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/tvSeason"
                    android:layout_width="40dp" android:layout_height="wrap_content"
                    android:text="1" android:textColor="#FFFFFF" android:textSize="16sp"
                    android:gravity="center" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/btnSeasonPlus"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:background="@drawable/btn_round_dark" android:text="+"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Episodio"
                    android:textColor="#AAFFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-bold"/>

                <TextView android:id="@+id/btnEpMinus"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:background="@drawable/btn_round_dark" android:text="−"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/tvEpisode"
                    android:layout_width="40dp" android:layout_height="wrap_content"
                    android:text="1" android:textColor="#FFFFFF" android:textSize="16sp"
                    android:gravity="center" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/btnEpPlus"
                    android:layout_width="32dp" android:layout_height="32dp"
                    android:background="@drawable/btn_round_dark" android:text="+"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnLoadEpisode"
                android:layout_width="match_parent" android:layout_height="40dp"
                android:background="@drawable/btn_ver_ahora_bg"
                android:gravity="center" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▶  Cargar episodio" android:textColor="#FFFFFF"
                    android:textSize="13sp" android:fontFamily="sans-serif-bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/loadingServers"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:indeterminateTint="#FF6B00"
            android:visibility="visible"/>

        <!-- Error -->
        <TextView
            android:id="@+id/errorServers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="Sin servidores disponibles"
            android:textColor="#66FFFFFF"
            android:textSize="13sp"
            android:visibility="gone"/>

        <!-- Lang tabs -->
        <LinearLayout
            android:id="@+id/langTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="10dp"
            android:gravity="start"
            android:visibility="gone">

            <TextView android:id="@+id/tabLatino"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:background="@drawable/tab_active" android:text="Latino"
                android:textColor="#FFFFFF" android:textSize="12sp" android:fontFamily="sans-serif-bold"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:gravity="center"/>

            <TextView android:id="@+id/tabEspanol"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_inactive" android:text="Español"
                android:textColor="#99FFFFFF" android:textSize="12sp"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:gravity="center"/>

            <TextView android:id="@+id/tabSubtitulado"
                android:layout_width="wrap_content" android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/tab_inactive" android:text="Sub"
                android:textColor="#99FFFFFF" android:textSize="12sp"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:gravity="center"/>
        </LinearLayout>

        <!-- Server rows -->
        <LinearLayout
            android:id="@+id/serverContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>

    </LinearLayout>

</FrameLayout>
