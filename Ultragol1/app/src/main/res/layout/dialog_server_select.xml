<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <!-- Tap outside to dismiss -->
    <View
        android:id="@+id/dialogDismiss"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Content info: bottom-left -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="40dp"
        android:orientation="horizontal"
        android:gravity="bottom">

        <ImageView
            android:id="@+id/dialogPoster"
            android:layout_width="60dp"
            android:layout_height="86dp"
            android:scaleType="centerCrop"
            android:background="@drawable/poster_glass_bg"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:gravity="bottom">

            <TextView
                android:id="@+id/dialogBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/detail_type_badge_bg"
                android:text="FILM"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.08"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"/>

            <TextView
                android:id="@+id/serverDialogTitle"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:fontFamily="sans-serif-black"
                android:maxLines="3"
                android:lineSpacingMultiplier="1.1"/>

            <!-- SOURCE FOUND -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/server_radio_dot"
                    android:layout_marginEnd="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOURCE FOUND"
                    android:textColor="#55FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.1"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- RIGHT PANEL: episode controls + servers -->
    <LinearLayout
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Episode controls (series only) — top of right panel -->
        <LinearLayout
            android:id="@+id/episodeSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/episode_card_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Temporada row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Temporada"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.05"/>

                <TextView android:id="@+id/btnSeasonMinus"
                    android:layout_width="30dp" android:layout_height="30dp"
                    android:background="@drawable/btn_round_dark" android:text="−"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"
                    android:clickable="true" android:focusable="true"/>

                <TextView android:id="@+id/tvSeason"
                    android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="1" android:textColor="#FFFFFF" android:textSize="15sp"
                    android:gravity="center" android:fontFamily="sans-serif-black"/>

                <TextView android:id="@+id/btnSeasonPlus"
                    android:layout_width="30dp" android:layout_height="30dp"
                    android:background="@drawable/btn_round_dark" android:text="+"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Episodio row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Episodio"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.05"/>

                <TextView android:id="@+id/btnEpMinus"
                    android:layout_width="30dp" android:layout_height="30dp"
                    android:background="@drawable/btn_round_dark" android:text="−"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"
                    android:clickable="true" android:focusable="true"/>

                <TextView android:id="@+id/tvEpisode"
                    android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="1" android:textColor="#FFFFFF" android:textSize="15sp"
                    android:gravity="center" android:fontFamily="sans-serif-black"/>

                <TextView android:id="@+id/btnEpPlus"
                    android:layout_width="30dp" android:layout_height="30dp"
                    android:background="@drawable/btn_round_dark" android:text="+"
                    android:textColor="#FFFFFF" android:textSize="18sp" android:gravity="center"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- OK button full width -->
            <LinearLayout android:id="@+id/btnLoadEpisode"
                android:layout_width="match_parent" android:layout_height="36dp"
                android:background="@drawable/btn_ver_ahora_bg"
                android:gravity="center" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▶  Cargar episodio" android:textColor="#FFFFFF"
                    android:textSize="12sp" android:fontFamily="sans-serif-bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/loadingServers"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="end"
            android:indeterminateTint="#FFFFFF"
            android:visibility="visible"/>

        <!-- Error -->
        <TextView
            android:id="@+id/errorServers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="Sin servidores"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:visibility="gone"/>

        <!-- Lang tabs -->
        <LinearLayout
            android:id="@+id/langTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:gravity="end"
            android:visibility="gone">
            <TextView android:id="@+id/tabLatino"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/tab_active" android:text="Latino"
                android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="sans-serif-bold"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:gravity="center"/>
            <TextView android:id="@+id/tabEspanol"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/tab_inactive" android:text="Español"
                android:textColor="#99FFFFFF" android:textSize="11sp"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:gravity="center"/>
            <TextView android:id="@+id/tabSubtitulado"
                android:layout_width="wrap_content" android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/tab_inactive" android:text="Sub"
                android:textColor="#99FFFFFF" android:textSize="11sp"
                android:paddingStart="12dp" android:paddingEnd="12dp" android:gravity="center"/>
        </LinearLayout>

        <!-- Server rows -->
        <LinearLayout
            android:id="@+id/serverContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </LinearLayout>

</FrameLayout>
