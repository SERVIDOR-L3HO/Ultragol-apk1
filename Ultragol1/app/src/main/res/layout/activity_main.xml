<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Fragment container — full screen, no bottom margin -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ── Drawer overlay (fullscreen, hidden by default) ── -->
    <FrameLayout
        android:id="@+id/drawerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E0000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#000000">

                <!-- ── Drawer header ── -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <!-- Logo -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ULTRA"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GOL"
                            android:textColor="@color/red_primary"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.NET"
                            android:textColor="@color/red_primary"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-black"
                            android:layout_gravity="bottom"
                            android:layout_marginBottom="2dp"/>
                    </LinearLayout>

                    <!-- Right icons: search + bell + close -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/drawerSearch"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:src="@android:drawable/ic_menu_search"
                            android:tint="#FFFFFF"
                            android:padding="6dp"
                            android:clickable="true"
                            android:focusable="true"/>
                        <TextView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:text="🔔"
                            android:textSize="18sp"
                            android:gravity="center"/>
                        <!-- Close X button -->
                        <TextView
                            android:id="@+id/drawerClose"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:text="✕"
                            android:textColor="#AAFFFFFF"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </FrameLayout>

                <!-- ── Nav items grid (2 columns) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="8dp">

                    <!-- Row 1: Inicio + Series -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:id="@+id/navInicio"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:background="@drawable/nav_card_bg"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⌂" android:textColor="#FFFFFF" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Inicio" android:textColor="#DDFFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/navSeries"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:background="@drawable/nav_card_bg"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▣" android:textColor="#FFFFFF" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Series" android:textColor="#DDFFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 2: Películas + Animes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:id="@+id/navMovies"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:background="@drawable/nav_card_bg"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="▢" android:textColor="#FFFFFF" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Películas" android:textColor="#DDFFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/navAnime"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:background="@drawable/nav_card_bg"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✦" android:textColor="#FFFFFF" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Animes" android:textColor="#DDFFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 3: Doramas + Buscar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:id="@+id/navDoramas"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:background="@drawable/nav_card_bg"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="❧" android:textColor="#FFFFFF" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Doramas" android:textColor="#DDFFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/navSearch"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:background="@drawable/nav_card_bg"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⌕" android:textColor="#FFFFFF" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Buscar" android:textColor="#DDFFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 4: Favoritos + Mi Lista -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:id="@+id/navFavorites"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:background="@drawable/nav_card_bg"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="♥" android:textColor="#FF5252" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Favoritos" android:textColor="#DDFFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/navMyList"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            android:orientation="vertical"
                            android:gravity="center_vertical"
                            android:paddingStart="16dp"
                            android:background="@drawable/nav_card_bg"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⊟" android:textColor="#4FC3F7" android:textSize="22sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Mi Lista" android:textColor="#DDFFFFFF" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── PLATAFORMAS section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="PLATAFORMAS"
                        android:textColor="#88FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.12"/>

                    <!-- Platform row 1 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <LinearLayout android:id="@+id/platNetflix" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NETFLIX" android:textColor="#E50914" android:textSize="13sp" android:fontFamily="sans-serif-black"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/platPrime" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prime Video" android:textColor="#00A8E0" android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/platDisney" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginStart="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Disney+" android:textColor="#113CCF" android:textSize="11sp" android:fontFamily="sans-serif-black"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Platform row 2 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <LinearLayout android:id="@+id/platApple" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Apple TV+" android:textColor="#FFFFFF" android:textSize="11sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/platHulu" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hulu" android:textColor="#1CE783" android:textSize="13sp" android:fontFamily="sans-serif-black"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/platHbo" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginStart="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HBO Max" android:textColor="#9B3DE8" android:textSize="11sp" android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Platform row 3 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:id="@+id/platCrunchyroll" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Crunchyroll" android:textColor="#F47521" android:textSize="10sp" android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/platAtx" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="At-X" android:textColor="#FFFFFF" android:textSize="13sp" android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>
                        <LinearLayout android:id="@+id/platTokyoMx" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginStart="4dp" android:background="@drawable/nav_card_bg" android:gravity="center" android:clickable="true" android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tokyo MX" android:textColor="#AAFFFFFF" android:textSize="10sp" android:fontFamily="sans-serif-bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="32dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>

</FrameLayout>
