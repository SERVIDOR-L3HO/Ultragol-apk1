<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="20dp"
    android:background="@drawable/live_section_glow_bg">

    <!-- Section header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <!-- Orange accent bar -->
        <View
            android:layout_width="4dp"
            android:layout_height="22dp"
            android:background="#FF6B00"
            android:layout_marginEnd="10dp"/>

        <!-- Title + subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EN VIVO AHORA"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.04"
                android:textAllCaps="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Transmisiones en directo"
                android:textColor="#88FF6B00"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Live pill -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EN VIVO"
            android:textColor="#FF00E676"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:background="@drawable/badge_live_green"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"/>
    </LinearLayout>

    <!-- Glass cards RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/liveCarouselRv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"/>

</LinearLayout>
