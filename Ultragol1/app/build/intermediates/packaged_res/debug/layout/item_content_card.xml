<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="130dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginStart="5dp"
    android:layout_marginEnd="5dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Poster image with overlays -->
    <FrameLayout
        android:layout_width="130dp"
        android:layout_height="185dp"
        android:background="@drawable/card_bg">

        <ImageView
            android:id="@+id/cardPoster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>

        <!-- Bottom gradient for readability -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_detail_bottom"/>

        <!-- Type badge: top-left -->
        <TextView
            android:id="@+id/cardBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="6dp"
            android:background="@drawable/badge_type_bg"
            android:text="SERIE"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:fontFamily="sans-serif-bold"
            android:letterSpacing="0.06"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <!-- Star + Rating: top-right -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/star_rating_bg"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★ "
                android:textColor="#FFD700"
                android:textSize="9sp"/>
            <TextView
                android:id="@+id/cardRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:fontFamily="sans-serif-bold"/>
        </LinearLayout>

        <!-- NEW badge bottom-left (for "NUEVO" items) -->
        <TextView
            android:id="@+id/cardNew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_margin="6dp"
            android:background="@drawable/badge_new"
            android:text="NUEVO"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:fontFamily="sans-serif-bold"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/cardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.2"/>

    <!-- Year -->
    <TextView
        android:id="@+id/cardYear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#77FFFFFF"
        android:textSize="11sp"/>
</LinearLayout>
