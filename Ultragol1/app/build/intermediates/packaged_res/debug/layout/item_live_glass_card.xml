<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/glassCard"
    android:layout_width="295dp"
    android:layout_height="150dp"
    android:layout_marginEnd="12dp"
    android:background="@drawable/glass_live_card_bg"
    android:clickable="true"
    android:focusable="true">

    <!-- Left dark area: logo -->
    <LinearLayout
        android:layout_width="98dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#1A000000">

        <ImageView
            android:id="@+id/cardLogo"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/live_logo_circle_bg"
            android:padding="9dp"
            android:scaleType="centerInside"
            android:contentDescription="logo"/>
    </LinearLayout>

    <!-- Right fade overlay from left area -->
    <View
        android:layout_width="24dp"
        android:layout_height="match_parent"
        android:layout_marginStart="84dp"
        android:background="@drawable/glass_fade_left_right"/>

    <!-- Right info column -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="108dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- League -->
        <TextView
            android:id="@+id/cardLeague"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFF6B00"
            android:textSize="9sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:letterSpacing="0.06"
            android:layout_marginBottom="5dp"/>

        <!-- Match title -->
        <TextView
            android:id="@+id/cardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.15"
            android:layout_marginBottom="5dp"/>

        <!-- Time -->
        <TextView
            android:id="@+id/cardTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#66FFFFFF"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="10dp"/>

        <!-- CTA button -->
        <TextView
            android:id="@+id/cardCta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶  Ver ahora"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/live_cta_glass_btn"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>
    </LinearLayout>

    <!-- EN VIVO badge — top left -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:text="● EN VIVO"
        android:textColor="#FF00E676"
        android:textSize="8sp"
        android:textStyle="bold"
        android:background="@drawable/badge_live_green"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"/>

    <!-- Server count badge — top right -->
    <TextView
        android:id="@+id/cardServerCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="8dp"
        android:textColor="#FFFF6B00"
        android:textSize="8sp"
        android:textStyle="bold"
        android:background="@drawable/live_server_number_bg"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone"/>

</FrameLayout>
