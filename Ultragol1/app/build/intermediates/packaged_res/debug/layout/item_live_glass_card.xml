<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/glassCard"
    android:layout_width="300dp"
    android:layout_height="182dp"
    android:layout_marginEnd="14dp"
    android:background="@drawable/live_card_main_bg"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <!-- Deep orange-to-blue gradient sweep (glass depth) -->
    <View
        android:layout_width="160dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/live_card_left_glow"/>

    <!-- Subtle shimmer top stripe -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="top"
        android:background="@drawable/live_card_top_shimmer"/>

    <!-- Left logo zone -->
    <LinearLayout
        android:layout_width="136dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Outer glow ring -->
        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center_horizontal">

            <!-- Outer ring (glow) -->
            <View
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/live_logo_outer_ring"/>

            <!-- Inner logo circle -->
            <ImageView
                android:id="@+id/cardLogo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/live_logo_ring"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:contentDescription="logo"/>
        </FrameLayout>

    </LinearLayout>

    <!-- Vertical separator — subtle gradient -->
    <View
        android:layout_width="1dp"
        android:layout_height="110dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="136dp"
        android:background="@drawable/divider_vertical_glass"/>

    <!-- Right glass info panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="150dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- League pill -->
        <TextView
            android:id="@+id/cardLeague"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFF6B00"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.10"
            android:maxLines="1"
            android:ellipsize="end"
            android:background="@drawable/league_pill_premium_bg"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="8dp"/>

        <!-- Match title -->
        <TextView
            android:id="@+id/cardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.25"
            android:layout_marginBottom="6dp"/>

        <!-- Time row -->
        <TextView
            android:id="@+id/cardTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="12dp"/>

        <!-- CTA button — glass style -->
        <TextView
            android:id="@+id/cardCta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶  Ver ahora"
            android:textColor="#FFFF6B00"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:gravity="center"
            android:background="@drawable/live_cta_glass_btn"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

    </LinearLayout>

    <!-- ● EN VIVO badge — top left -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/badge_live_green_premium"
        android:paddingStart="8dp"
        android:paddingEnd="9dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <View
            android:layout_width="5dp"
            android:layout_height="5dp"
            android:background="@drawable/live_dot_pulse"
            android:layout_marginEnd="5dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EN VIVO"
            android:textColor="#FF00E676"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.07"/>
    </LinearLayout>

    <!-- Server count badge — top right -->
    <TextView
        android:id="@+id/cardServerCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="10dp"
        android:textColor="#FFFF6B00"
        android:textSize="8sp"
        android:textStyle="bold"
        android:background="@drawable/live_server_number_bg"
        android:paddingStart="9dp"
        android:paddingEnd="9dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone"/>

</FrameLayout>
