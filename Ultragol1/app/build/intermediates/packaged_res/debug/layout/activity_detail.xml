<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Backdrop full width -->
    <ImageView
        android:id="@+id/detailBackdrop"
        android:layout_width="match_parent"
        android:layout_height="290dp"
        android:scaleType="centerCrop"/>

    <!-- Backdrop bottom gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="290dp"
        android:background="@drawable/gradient_detail_overlay"/>

    <!-- Top bar shadow -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/gradient_top_black"/>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Poster area: sits over backdrop -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="290dp">
                <ImageView
                    android:id="@+id/detailPoster"
                    android:layout_width="155dp"
                    android:layout_height="225dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:background="@drawable/poster_glass_bg"
                    android:elevation="6dp"/>
            </FrameLayout>

            <!-- Info section — plain black background -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#000000"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp">

                <!-- Type badge + C rating badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/detailTypeBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/detail_type_badge_bg"
                        android:text="PELÍCULA"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.06"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>

                    <TextView
                        android:id="@+id/detailBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/badge_rating_pill"
                        android:text="C"
                        android:textColor="#AAFFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-bold"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <!-- Title -->
                <TextView
                    android:id="@+id/detailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-black"
                    android:lineSpacingMultiplier="1.1"/>

                <!-- Meta: year · duration · lang -->
                <TextView
                    android:id="@+id/detailMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp"
                    android:letterSpacing="0.02"/>

                <!-- ◆ Rating pill -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/rating_pill_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="◆ "
                        android:textColor="#4FC3F7"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/detailRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-bold"/>
                </LinearLayout>

                <!-- Genre chips row -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none"
                    android:overScrollMode="never">
                    <LinearLayout
                        android:id="@+id/genreChips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"/>
                </HorizontalScrollView>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="#1AFFFFFF"/>

                <!-- Synopsis text -->
                <TextView
                    android:id="@+id/detailOverview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="#DDFFFFFF"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.65"
                    android:fontFamily="sans-serif"/>

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="22dp">

                    <LinearLayout
                        android:id="@+id/btnFavorite"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/action_btn_bg"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="♡  "
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Favorito"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnMyList"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/action_btn_bg"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⊟  "
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mi Lista"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnPlay"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/action_btn_bg"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="◎  "
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vista"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="8dp"/>
            </LinearLayout>

            <!-- Related section -->
            <include android:id="@+id/rowRelated" layout="@layout/row_section"/>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#000000"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="32dp"
                android:paddingBottom="40dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ULTRA"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GOL"
                        android:textColor="@color/red_primary"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.NET"
                        android:textColor="@color/red_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_gravity="bottom"
                        android:layout_marginBottom="2dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Tu plataforma de streaming en español Latino para ver\npelículas, series y animes online gratis."
                    android:textColor="#66FFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Back button — LAST so it renders on top of scroll content -->
    <FrameLayout
        android:id="@+id/btnDetailBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_margin="16dp"
        android:background="@drawable/back_btn_glass"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="20sp"/>
    </FrameLayout>
</FrameLayout>
