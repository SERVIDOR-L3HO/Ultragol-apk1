<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── TopBar ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@color/bg_primary">

            <!-- Logo -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ULTRA"
                    android:textColor="#FFFFFF"
                    android:textSize="21sp"
                    android:fontFamily="sans-serif-black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GOL"
                    android:textColor="@color/red_primary"
                    android:textSize="21sp"
                    android:fontFamily="sans-serif-black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=".NET"
                    android:textColor="@color/red_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="2dp"/>
            </LinearLayout>

            <!-- Íconos derecha -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:id="@+id/btnSearch"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@android:drawable/ic_menu_search"
                    android:tint="#FFFFFF"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:text="🔔"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>
                <TextView
                    android:id="@+id/btnMenu"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:text="☰"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </FrameLayout>

        <!-- ── Hero Banner ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="520dp">
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/heroBanner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <LinearLayout
                android:id="@+id/bannerDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal"
                android:gravity="center"/>
        </FrameLayout>

        <!-- ── Rows ── -->
        <include android:id="@+id/rowTrending" layout="@layout/row_section"/>
        <include android:id="@+id/rowNew"      layout="@layout/row_section"/>
        <include android:id="@+id/rowMovies"   layout="@layout/row_section"/>
        <include android:id="@+id/rowSeries"   layout="@layout/row_section"/>
        <include android:id="@+id/rowAnime"    layout="@layout/row_section"/>
        <include android:id="@+id/rowDoramas"  layout="@layout/row_section"/>
        <include android:id="@+id/rowTop10"    layout="@layout/row_section"/>

        <View android:layout_width="match_parent" android:layout_height="24dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
