<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_radial_splash"/>

    <View
        android:id="@+id/ringOuter"
        android:layout_width="380dp"
        android:layout_height="380dp"
        android:layout_gravity="center"
        android:background="@drawable/splash_ring_outer"/>

    <View
        android:id="@+id/ringMid"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:background="@drawable/splash_ring_mid"/>

    <View
        android:id="@+id/ringInner"
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:layout_gravity="center"
        android:background="@drawable/splash_ring_inner"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:background="@drawable/splash_icon_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚽"
                android:textSize="28sp"/>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/splashLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ULTRA"
                android:textColor="#FFFFFF"
                android:textSize="44sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GOL"
                android:textColor="@color/orange_primary"
                android:textSize="44sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#CCFFFFFF"
                android:textSize="30sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginStart="2dp"/>
        </LinearLayout>

        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            android:layout_marginTop="14dp"
            android:layout_gravity="center"
            android:background="@color/orange_primary"/>

        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Streaming sin límites"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:letterSpacing="0.12"
            android:visibility="invisible"/>

        <LinearLayout
            android:id="@+id/splashProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:visibility="invisible">
            <View
                android:id="@+id/dot1"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/splash_dot"/>
            <View
                android:id="@+id/dot2"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/splash_dot_dim"/>
            <View
                android:id="@+id/dot3"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/splash_dot_dim"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="#33FFFFFF"
            android:textSize="11sp"
            android:letterSpacing="0.1"/>
    </LinearLayout>

</FrameLayout>
