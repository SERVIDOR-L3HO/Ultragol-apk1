<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Fondo radial sutil -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_radial_splash"/>

    <!-- Contenido central -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Logo Ultragol -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="280dp"
            android:layout_height="90dp"
            android:src="@drawable/logo_ultragol_splash"
            android:scaleType="fitCenter"
            android:alpha="0"/>

        <!-- Línea divisoria elegante -->
        <View
            android:id="@+id/splashDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:layout_gravity="center"
            android:background="#40FFFFFF"
            android:alpha="0"/>

        <!-- Tagline -->
        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Streaming sin límites"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.18"
            android:fontFamily="sans-serif-light"
            android:alpha="0"/>

        <!-- Dots de carga -->
        <LinearLayout
            android:id="@+id/splashProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="56dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:alpha="0">
            <View
                android:id="@+id/dot1"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="7dp"
                android:background="@drawable/splash_dot"/>
            <View
                android:id="@+id/dot2"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="7dp"
                android:background="@drawable/splash_dot_dim"/>
            <View
                android:id="@+id/dot3"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/splash_dot_dim"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Versión abajo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="38dp"
        android:text="ULTRAGOL1"
        android:textColor="#22FFFFFF"
        android:textSize="10sp"
        android:letterSpacing="0.25"
        android:fontFamily="sans-serif-medium"/>

</FrameLayout>
