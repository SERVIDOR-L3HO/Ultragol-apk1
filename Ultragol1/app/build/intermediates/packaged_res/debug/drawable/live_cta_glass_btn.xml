<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#CC4400" android:endColor="#991E00" android:angle="135"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#FF6B00" android:endColor="#CC3300" android:angle="135"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
