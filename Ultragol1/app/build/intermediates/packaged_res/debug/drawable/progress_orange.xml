<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle"><solid android:color="#33FFFFFF"/></shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle"><solid android:color="#FF6B00"/></shape>
        </clip>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <clip>
            <shape android:shape="rectangle"><solid android:color="#66FF6B00"/></shape>
        </clip>
    </item>
</layer-list>
