<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#2A1200" android:centerColor="#141428" android:endColor="#0A0A1E" android:angle="135"/>
            <stroke android:width="1.5dp" android:color="#AAFF6B00"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#1C0C00" android:centerColor="#0E0E22" android:endColor="#08081A" android:angle="135"/>
            <stroke android:width="1dp" android:color="#55FF6B00"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>
</selector>
