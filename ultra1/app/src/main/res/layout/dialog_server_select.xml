<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_bottom_sheet_premium"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/sheet_handle"/>

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <View
            android:layout_width="3dp"
            android:layout_height="22dp"
            android:background="@drawable/accent_bar"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPRODUCIR"
                android:textColor="#FF6B00"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>

            <TextView
                android:id="@+id/serverDialogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Episode Section (TV only) -->
    <LinearLayout
        android:id="@+id/episodeSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/glass_stat_bg"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECCIONAR EPISODIO"
            android:textColor="#FF6B00"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMPORADA"
                    android:textColor="#6060A0"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/picker_bg">

                    <TextView
                        android:id="@+id/btnSeasonMinus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#8722;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tvSeason"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/btnSeasonPlus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#43;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EPISODIO"
                    android:textColor="#6060A0"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/picker_bg">

                    <TextView
                        android:id="@+id/btnEpMinus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#8722;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tvEpisode"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/btnEpPlus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#43;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/serverLoadingLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:visibility="visible">

        <ProgressBar
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:indeterminateTint="#FF6B00"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Buscando servidores…"
            android:textColor="#8080B0"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Language tabs -->
    <LinearLayout
        android:id="@+id/langTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tabLatino"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Latino"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginEnd="6dp"
            android:background="@drawable/server_chip_active"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabEspanol"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Espanol"
            android:textColor="#B0B0CC"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"
            android:background="@drawable/server_chip"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Dynamic servers container -->
    <LinearLayout
        android:id="@+id/serversLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"/>

    <!-- Legacy server buttons (hidden, kept for compat) -->
    <View android:id="@+id/btnServer1" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/btnServer2" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/btnServer3" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

</LinearLayout>
