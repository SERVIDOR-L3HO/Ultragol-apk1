<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header bar with glass -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/topbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:background="@drawable/topbar_glass_bg">

        <View
            android:layout_width="3dp"
            android:layout_height="22dp"
            android:background="@drawable/accent_bar"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/sectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Películas"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"/>

        <!-- Sort icon -->
        <TextView
            android:id="@+id/sortIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:text="&#8645;"
            android:textSize="20sp"
            android:textColor="#B0B0CC"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/icon_button_bg"/>

        <!-- Filter icon -->
        <TextView
            android:id="@+id/filterIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:gravity="center"
            android:text="&#9965;"
            android:textSize="17sp"
            android:textColor="#B0B0CC"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/icon_button_bg"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/search_background">

            <TextView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:text="&#128269;"
                android:textSize="13sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="12dp"
                android:text="@string/search_hint"
                android:textColor="#5A5A80"
                android:textSize="13sp"/>
        </RelativeLayout>
    </LinearLayout>

    <!-- Content grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/contentGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never"/>

</LinearLayout>
