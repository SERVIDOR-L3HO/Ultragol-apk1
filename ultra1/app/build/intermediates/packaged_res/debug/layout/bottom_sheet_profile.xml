<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_bg"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#44FF6B00"/>

    <!-- Avatar + nombre -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- Avatar circle -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:gravity="center"
            android:background="@drawable/glass_stat_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#128100;"
                android:textSize="38sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuario Premium"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#11088; PLAN PREMIUM"
            android:textColor="#FF6B00"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Stats row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/glass_stat_bg"
            android:padding="12dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:id="@+id/tvFavCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FF6B00"
                android:textSize="22sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#10084; Mi Lista"
                android:textColor="#6060A0"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/glass_stat_bg"
            android:padding="12dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HD"
                android:textColor="#FF6B00"
                android:textSize="22sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#127916; Calidad"
                android:textColor="#6060A0"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/glass_stat_bg"
            android:padding="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="∞"
                android:textColor="#FF6B00"
                android:textSize="22sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#127911; Canales"
                android:textColor="#6060A0"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#1AFF6B00" android:layout_marginBottom="8dp"/>

    <!-- Menu items -->
    <LinearLayout
        android:id="@+id/menuMyList"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:clickable="true"
        android:focusable="true">
        <TextView android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="&#10084;" android:textSize="18sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Mi Lista" android:textColor="#CCFFFFFF"
            android:textSize="15sp" android:layout_marginStart="14dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#8250;" android:textColor="#FF6B00" android:textSize="22sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuHistory"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:clickable="true"
        android:focusable="true">
        <TextView android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="&#128336;" android:textSize="18sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Historial" android:textColor="#CCFFFFFF"
            android:textSize="15sp" android:layout_marginStart="14dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#8250;" android:textColor="#FF6B00" android:textSize="22sp"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menuSettings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:clickable="true"
        android:focusable="true">
        <TextView android:layout_width="32dp" android:layout_height="wrap_content"
            android:text="&#9881;" android:textSize="18sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Configuración" android:textColor="#CCFFFFFF"
            android:textSize="15sp" android:layout_marginStart="14dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&#8250;" android:textColor="#FF6B00" android:textSize="22sp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#1AFF6B00" android:layout_marginTop="8dp" android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">
        <TextView
            android:id="@+id/btnSignOut"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="&#128682; Cerrar sesión"
            android:textColor="#FF5555"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/glass_button_outline"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>
