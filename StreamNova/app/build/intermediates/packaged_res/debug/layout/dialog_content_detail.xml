<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_modal_premium">

    <!-- Hero image area -->
    <RelativeLayout
        android:id="@+id/modalHeroBg"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="@drawable/gradient_movie">

        <ImageView
            android:id="@+id/modalImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null"/>

        <!-- Top gradient scrim -->
        <View
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_alignParentTop="true"
            android:background="@drawable/gradient_hero"/>

        <!-- Bottom scrim -->
        <View
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/gradient_scrim"/>

        <!-- Orange accent line at top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_alignParentTop="true"
            android:background="@drawable/orange_glow_line"/>

        <!-- Badge bottom-left -->
        <TextView
            android:id="@+id/modalBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_margin="12dp"
            android:text="HD"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:background="@drawable/badge_background"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <!-- Close button top-right -->
        <TextView
            android:id="@+id/btnClose"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="10dp"
            android:gravity="center"
            android:text="&#10005;"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/close_button_bg"
            android:clickable="true"
            android:focusable="true"/>
    </RelativeLayout>

    <!-- Content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="18dp">

        <!-- Title row -->
        <TextView
            android:id="@+id/modalTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título"
            android:textColor="#FFFFFF"
            android:textSize="21sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="12dp"/>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Rating -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/glass_stat_premium"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#9733;"
                    android:textSize="14sp"
                    android:textColor="#FF6B00"/>
                <TextView
                    android:id="@+id/modalRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9.2"
                    android:textColor="#FF6B00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RATING"
                    android:textColor="#44FF8844"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <!-- Genre -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/glass_stat_premium"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#9654;"
                    android:textSize="12sp"
                    android:textColor="#8080CC"/>
                <TextView
                    android:id="@+id/modalGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acción"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GÉNERO"
                    android:textColor="#44AAAACC"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>

            <!-- Year -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/glass_stat_premium">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128197;"
                    android:textSize="12sp"
                    android:textColor="#8080CC"/>
                <TextView
                    android:id="@+id/modalYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AÑO"
                    android:textColor="#44AAAACC"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="1dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Overview -->
        <TextView
            android:id="@+id/modalOverview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#8888BB"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.4"
            android:maxLines="4"
            android:ellipsize="end"
            android:layout_marginBottom="14dp"
            android:visibility="gone"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/orange_glow_line"
            android:alpha="0.25"
            android:layout_marginBottom="14dp"/>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnModalPlay"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="&#9654;  REPRODUCIR"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:background="@drawable/play_button_bg"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/btnModalList"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="+  MI LISTA"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:background="@drawable/glass_button_outline"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
