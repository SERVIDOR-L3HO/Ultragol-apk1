<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_modal_bg">

    <!-- Hero area -->
    <RelativeLayout
        android:id="@+id/modalHeroBg"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/gradient_sport">

        <TextView
            android:id="@+id/modalEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="&#127942;"
            android:textSize="60sp"/>

        <!-- Orange top glow -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/orange_glow_line"
            android:layout_alignParentTop="true"/>

        <TextView
            android:id="@+id/modalBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_margin="12dp"
            android:text="HD"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:background="@drawable/badge_background"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/gradient_scrim"/>

        <!-- Close button -->
        <TextView
            android:id="@+id/btnClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="10dp"
            android:gravity="center"
            android:text="&#10005;"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/close_button_bg"
            android:clickable="true"
            android:focusable="true"/>
    </RelativeLayout>

    <!-- Content info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/modalTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="14dp"/>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <!-- Rating stat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/glass_stat_bg"
                android:padding="10dp"
                android:layout_marginEnd="7dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#11088;"
                    android:textSize="16sp"/>
                <TextView
                    android:id="@+id/modalRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9.2"
                    android:textColor="@color/star_gold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RATING"
                    android:textColor="#5A5A80"
                    android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Genre stat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/glass_stat_bg"
                android:padding="10dp"
                android:layout_marginEnd="7dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#127909;"
                    android:textSize="16sp"/>
                <TextView
                    android:id="@+id/modalGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acción"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GÉNERO"
                    android:textColor="#5A5A80"
                    android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Year stat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/glass_stat_bg"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128197;"
                    android:textSize="16sp"/>
                <TextView
                    android:id="@+id/modalYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AÑO"
                    android:textColor="#5A5A80"
                    android:textSize="9sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FF6B00"
            android:layout_marginBottom="14dp"/>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnModalPlay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="&#9654;  REPRODUCIR"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/play_button_bg"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/btnModalList"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="&#43;  MI LISTA"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/glass_button_outline"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
