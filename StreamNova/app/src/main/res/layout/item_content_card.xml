<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="130dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginEnd="10dp"
    android:clickable="true"
    android:focusable="true">

    <RelativeLayout
        android:id="@+id/thumbnailContainer"
        android:layout_width="match_parent"
        android:layout_height="195dp"
        android:background="@drawable/gradient_movie">

        <ImageView
            android:id="@+id/thumbnailImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/badgeView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:layout_margin="7dp"
            android:text="HD"
            android:textColor="#FFFFFF"
            android:textSize="8sp"
            android:textStyle="bold"
            android:background="@drawable/badge_background"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/favoriteBtn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="5dp"
            android:gravity="center"
            android:text="&#9829;"
            android:textColor="#55FF6B8A"
            android:textSize="13sp"
            android:background="@drawable/icon_button_small_bg"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/card_bottom_glass"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/ratingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#9733; 8.5"
                android:textColor="@color/star_gold"
                android:textSize="10sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/qualityTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4K"
                android:textColor="@color/color_primary"
                android:textSize="9sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </RelativeLayout>

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Título"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="6dp"
        android:fontFamily="sans-serif-medium"/>

    <TextView
        android:id="@+id/genreText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Acción • 2024"
        android:textColor="#5A5A80"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="2dp"/>

</LinearLayout>
