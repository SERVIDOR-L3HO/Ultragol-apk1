<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Fullscreen video container -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:visibility="gone"/>

    <!-- Normal WebView container -->
    <LinearLayout
        android:id="@+id/webviewContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#CC080812"
            android:paddingStart="6dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/btnPlayerBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                android:gravity="center"
                android:text="&#8592;"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/playerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnPlayerBack"
                android:layout_toStartOf="@+id/playerTitleEnd"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <View
                android:id="@+id/playerTitleEnd"
                android:layout_width="8dp"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_alignParentBottom="true"
                android:background="#33FF6B00"/>
        </RelativeLayout>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/playerProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="#FF6B00"
            android:progressBackgroundTint="#22FFFFFF"
            android:max="100"
            android:visibility="gone"/>

        <!-- WebView -->
        <WebView
            android:id="@+id/playerWebView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#000000"/>

    </LinearLayout>

</FrameLayout>
