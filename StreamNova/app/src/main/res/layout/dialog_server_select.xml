<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_bottom_sheet_premium"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/sheet_handle"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <View
            android:layout_width="3dp"
            android:layout_height="22dp"
            android:background="@drawable/accent_bar"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPRODUCIR"
                android:textColor="#FF6B00"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>
            <TextView
                android:id="@+id/serverDialogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Episode Section (series/anime/dorama) -->
    <LinearLayout
        android:id="@+id/episodeSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/glass_stat_bg"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECCIONAR EPISODIO"
            android:textColor="#FF6B00"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Season -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMPORADA"
                    android:textColor="#6060A0"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/picker_bg">
                    <TextView
                        android:id="@+id/btnSeasonMinus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#8722;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>
                    <TextView
                        android:id="@+id/tvSeason"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/btnSeasonPlus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#43;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Episode -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EPISODIO"
                    android:textColor="#6060A0"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/picker_bg">
                    <TextView
                        android:id="@+id/btnEpMinus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#8722;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>
                    <TextView
                        android:id="@+id/tvEpisode"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/btnEpPlus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#43;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Load episode button -->
        <TextView
            android:id="@+id/btnLoadEpisode"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="BUSCAR EPISODIO"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/chip_active"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Language tabs -->
    <LinearLayout
        android:id="@+id/langTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tabLatino"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="Latino"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/chip_active"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabEspanol"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="Espanol"
            android:textColor="#B0B0CC"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/chip_inactive"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tabSubtitulado"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="Sub"
            android:textColor="#B0B0CC"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/chip_inactive"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Servers label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="10dp"
        android:text="SELECCIONAR SERVIDOR"
        android:textColor="#6060A0"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"/>

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/loadingServers"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminateTint="#FF6B00"
            style="?android:attr/progressBarStyle"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Cargando servidores..."
            android:textColor="#6060A0"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Error state -->
    <LinearLayout
        android:id="@+id/errorServers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/glass_stat_bg"
        android:padding="12dp"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="!"
            android:textColor="#FF6B00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="No se pudieron cargar los servidores. Usando servidor de respaldo."
            android:textColor="#7070A0"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Dynamic server list -->
    <LinearLayout
        android:id="@+id/serverContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

</LinearLayout>
