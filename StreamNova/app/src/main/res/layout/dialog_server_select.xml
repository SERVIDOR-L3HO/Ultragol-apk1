<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_bottom_sheet_premium"
    android:paddingBottom="28dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/sheet_handle"/>

    <!-- Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <View
            android:layout_width="3dp"
            android:layout_height="22dp"
            android:background="@drawable/accent_bar"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPRODUCIR"
                android:textColor="#FF6B00"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"/>

            <TextView
                android:id="@+id/serverDialogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Episode Section (TV only) -->
    <LinearLayout
        android:id="@+id/episodeSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:background="@drawable/glass_stat_bg"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECCIONAR EPISODIO"
            android:textColor="#FF6B00"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Season picker -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TEMPORADA"
                    android:textColor="#6060A0"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/picker_bg">

                    <TextView
                        android:id="@+id/btnSeasonMinus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#8722;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tvSeason"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/btnSeasonPlus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#43;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Episode picker -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EPISODIO"
                    android:textColor="#6060A0"
                    android:textSize="8sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/picker_bg">

                    <TextView
                        android:id="@+id/btnEpMinus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#8722;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tvEpisode"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/btnEpPlus"
                        android:layout_width="42dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="&#43;"
                        android:textColor="#FF6B00"
                        android:textSize="20sp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Servers label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="10dp"
        android:text="SELECCIONAR SERVIDOR"
        android:textColor="#6060A0"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"/>

    <!-- Server 1 -->
    <LinearLayout
        android:id="@+id/btnServer1"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/server_chip_active"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_indicator"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UnlimPlay"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servidor Principal  •  HD"
                android:textColor="#7070A0"
                android:textSize="10sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#9654;"
            android:textColor="#FF6B00"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Server 2 -->
    <LinearLayout
        android:id="@+id/btnServer2"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/server_chip"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_inactive"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VidSrc"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servidor 2  •  HD"
                android:textColor="#5050A0"
                android:textSize="10sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#9654;"
            android:textColor="#5050A0"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Server 3 -->
    <LinearLayout
        android:id="@+id/btnServer3"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/server_chip"
        android:padding="14dp"
        android:clickable="true"
        android:focusable="true">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_inactive"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2Embed"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Servidor 3  •  HD"
                android:textColor="#5050A0"
                android:textSize="10sp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#9654;"
            android:textColor="#5050A0"
            android:textSize="16sp"/>
    </LinearLayout>

</LinearLayout>
