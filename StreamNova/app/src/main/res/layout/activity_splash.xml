<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Deep space radial glow background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_hero"
        android:alpha="0.25"/>

    <!-- Animated orange glow circle behind logo -->
    <View
        android:id="@+id/glowCircle"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_centerInParent="true"
        android:background="@drawable/splash_glow"
        android:alpha="0"/>

    <!-- Logo container: image + tagline -->
    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0">

        <!-- Ultragol icon (round ball logo) -->
        <ImageView
            android:id="@+id/logoIcon"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher_round"
            android:scaleType="centerCrop"/>

        <!-- Ultragol text logo -->
        <ImageView
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:src="@drawable/ultragol_logo"
            android:scaleType="fitCenter"
            android:layout_marginTop="18dp"/>

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textColor="#7070A0"
            android:textSize="12sp"
            android:letterSpacing="0.12"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

    <!-- Loading indicator at bottom -->
    <LinearLayout
        android:id="@+id/loadingContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="56dp"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0">

        <ProgressBar
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:indeterminateTint="@color/color_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_loading"
            android:textColor="#5A5A80"
            android:textSize="12sp"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.12"/>
    </LinearLayout>

    <!-- Version tag -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"
        android:text="v2.0"
        android:textColor="#30507070"
        android:textSize="10sp"/>

</RelativeLayout>
