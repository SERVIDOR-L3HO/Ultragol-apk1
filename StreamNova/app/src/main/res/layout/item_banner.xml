<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/bannerBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_hero"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp">

        <!-- Content emoji / thumbnail area -->
        <TextView
            android:id="@+id/bannerEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="32dp"
            android:text="&#127942;"
            android:textSize="72sp"/>

        <!-- Orange glow strip at top -->
        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="@drawable/orange_glow_line"
            android:layout_alignParentTop="true"/>

        <!-- Glass info overlay at bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@drawable/banner_glass_bottom"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Live / Featured badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/bannerBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESTACADO"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/badge_live"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

                <TextView
                    android:id="@+id/bannerYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024"
                    android:textColor="#8080B0"
                    android:textSize="11sp"
                    android:layout_marginStart="10dp"/>

                <TextView
                    android:id="@+id/bannerRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#11088; 9.2"
                    android:textColor="@color/star_gold"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/bannerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Título del Contenido"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/bannerDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción del contenido destacado"
                android:textColor="#9090C0"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="14dp"/>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnPlay"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="&#9654;  REPRODUCIR"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/play_button_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btnInfo"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:gravity="center"
                    android:text="&#9432;"
                    android:textColor="#CCFFFFFF"
                    android:textSize="20sp"
                    android:background="@drawable/info_button_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btnFavorite"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:gravity="center"
                    android:text="&#10084;"
                    android:textColor="#FF6B8A"
                    android:textSize="18sp"
                    android:background="@drawable/info_button_bg"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
